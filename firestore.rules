rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // System collections - unconditional access
    match /DeletionConfirmations/{doc=**} {
      allow read, write: if true;
    }
    match /DeletedAccounts/{doc=**} {
      allow read, write: if true;
    }
    match /AccountDeletionJobs/{doc=**} {
      allow read, write: if true;
    }
    
    // Public collections
    match /CoinPlans/{planId} {
      allow read: if true;
      allow write: if false;
    }
    
    // User documents and all subcollections
    // Allows authenticated user to manage their own data
    match /Users/{uid}/{document=**} {
      allow read, write: if request.auth.uid == uid;
    }
    
    // Also allow reading/writing the Users doc itself
    match /Users/{uid} {
      allow read, write: if request.auth.uid == uid;
    }
    
    // Default: allow authenticated users to read/write other collections
    match /{path=**} {
      allow read, write: if request.auth != null;
    }
  }
}
